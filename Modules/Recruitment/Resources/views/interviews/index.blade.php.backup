@section('script')
<script>
    $(document).ready(function() {
        console.log('🎯 Interview page loaded - using simple table with reliable filters');
        
        // Simple and reliable filter functionality - auto-submit form when any filter changes
        $('#filterForm select, #filterForm input[type="date"]').on('change', function() {
            console.log('🔄 Filter changed: ' + $(this).attr('name') + ' = ' + $(this).val());
            console.log('📋 Submitting form for immediate filtering...');
            $(this).closest('form')[0].submit();
        });
        
        // Remove any temporary alerts
        setTimeout(function() {
            $('.alert-success, .alert-info').not('.alert-permanent').fadeOut();
        }, 3000);
    });

    // Interview management functions

    // Complete interview
    $('.complete-interview').click(function() {
        const interviewId = $(this).data('id');
        $('#completeInterviewId').val(interviewId);
        $('#completeModal').modal('show');
    });

    // Complete interview form submission  
    $('#completeForm').submit(function(e) {
        e.preventDefault();
        
        const formData = $(this).serialize();
        const interviewId = $('#completeInterviewId').val();
        
        $.ajax({
            url: `/recruitment/interviews/${interviewId}/complete`,
            method: 'POST',
            data: formData,
            headers: {
                'X-CSRF-TOKEN': $('meta[name="csrf-token"]').attr('content')
            },
            success: function(response) {
                if (response.success) {
                    toastr.success(response.message || 'Interview completed successfully!');
                    $('#completeModal').modal('hide');
                    location.reload();
                } else {
                    toastr.error(response.message || 'Failed to complete interview');
                }
            },
            error: function(xhr) {
                let message = 'Failed to complete interview';
                if (xhr.responseJSON && xhr.responseJSON.message) {
                    message = xhr.responseJSON.message;
                } else if (xhr.responseJSON && xhr.responseJSON.errors) {
                    message = Object.values(xhr.responseJSON.errors).join(', ');
                }
                toastr.error(message);
            }
        });
    });

    // Reschedule interview
    $('.reschedule-interview').click(function() {
        const interviewId = $(this).data('id');
        $('#rescheduleInterviewId').val(interviewId);
        $('#rescheduleModal').modal('show');
    });

    // Reschedule interview form submission
    $('#rescheduleForm').submit(function(e) {
        e.preventDefault();
        
        const formData = $(this).serialize();
        const interviewId = $('#rescheduleInterviewId').val();
        
        $.ajax({
            url: `/recruitment/interviews/${interviewId}/reschedule`,
            method: 'POST',
            data: formData,
            headers: {
                'X-CSRF-TOKEN': $('meta[name="csrf-token"]').attr('content')
            },
            success: function(response) {
                if (response.success) {
                    toastr.success(response.message || 'Interview rescheduled successfully!');
                    $('#rescheduleModal').modal('hide');
                    location.reload();
                } else {
                    toastr.error(response.message || 'Failed to reschedule interview');
                }
            },
            error: function() {
                toastr.error('Something went wrong!');
            }
        });
    });

    // Delete interview with confirmation
    $(document).on('click', '.delete-interview', function(e) {
        e.preventDefault();
        let interviewId = $(this).data('id');
        let candidateName = $(this).data('candidate') || 'this candidate';
        
        Swal.fire({
            title: 'Are you sure?',
            text: `This will permanently delete the interview with ${candidateName}. This action cannot be undone!`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'Cancel'
        }).then((result) => {
            if (result.isConfirmed) {
                deleteInterview(interviewId);
            }
        });
    });

    function deleteInterview(id) {
        console.log('Attempting to delete interview ID:', id);
        
        // Show loading state
        Swal.fire({
            title: 'Deleting...',
            text: 'Please wait while we delete the interview.',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        $.ajax({
            url: `/recruitment/interviews/${id}`,
            type: 'DELETE',
            headers: {
                'X-CSRF-TOKEN': $('meta[name="csrf-token"]').attr('content'),
                'Accept': 'application/json'
            },
            success: function(response) {
                console.log('Delete response:', response);
                
                if (response.success) {
                    Swal.fire('Deleted!', response.message, 'success').then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire('Error!', response.message || 'Failed to delete interview', 'error');
                }
            },
            error: function(xhr, status, error) {
                console.error('Delete failed:', xhr.status, error, xhr.responseText);
                
                let errorMessage = 'Failed to delete interview';
                if (xhr.status === 403) {
                    errorMessage = 'Permission denied. You do not have access to delete interviews.';
                } else if (xhr.responseJSON && xhr.responseJSON.message) {
                    errorMessage = xhr.responseJSON.message;
                } else if (xhr.status === 404) {
                    errorMessage = 'Interview not found.';
                } else if (xhr.status >= 500) {
                    errorMessage = 'Server error. Please try again later.';
                }
                
                Swal.fire('Error!', errorMessage, 'error');
            }
        });
    }

    // Toast notification helper
    function showToast(message, type = 'success') {
        const toast = document.createElement('div');
        toast.className = `alert alert-${type === 'success' ? 'success' : 'danger'} alert-dismissible fade show position-fixed`;
        toast.style.cssText = 'top: 20px; right: 20px; z-index: 1050; min-width: 300px;';
        toast.innerHTML = message + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
        
        document.body.appendChild(toast);
        
        // Auto remove after 5 seconds
        setTimeout(() => {
            toast.remove();
        }, 5000);
    }

    // Clean up any remaining DataTable references (prevent conflicts)
    if (typeof $.fn.DataTable !== 'undefined' && $.fn.DataTable.isDataTable('#interviewsTable')) {
        console.log('Cleaning up existing DataTable...');
        $('#interviewsTable').DataTable().destroy();
    }
</script>
@endsection
                },
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'X-CSRF-TOKEN': $('meta[name="csrf-token"]').attr('content')
                },
                error: function (xhr, error, thrown) {
                    console.error('DataTable AJAX Error:', {
                        status: xhr.status,
                        responseText: xhr.responseText,
                        error: error,
                        thrown: thrown
                    });
                    alert('Failed to load interviews. Status: ' + xhr.status);
                }
            },
            columns: [
                {data: 'DT_RowIndex', name: 'DT_RowIndex', orderable: false, searchable: false, width: '5%'},
                {data: 'candidate', name: 'application.candidate_name', width: '15%'},
                {data: 'job_title', name: 'application.job.title', width: '15%'},
                {data: 'interviewer_name', name: 'interviewer.name', width: '12%'},
                {data: 'scheduled_date', name: 'scheduled_at', width: '12%'},
                {data: 'type_badge', name: 'type', orderable: false, width: '8%'},
                {data: 'status_badge', name: 'status', orderable: false, width: '8%'},
                {data: 'duration', name: 'duration_minutes', width: '10%'},
                {data: 'action', name: 'action', orderable: false, searchable: false, width: '15%'}
            ],
            order: [[4, 'asc']],
            responsive: true
        });
        
                    console.log('✅ DataTable initialized successfully');
        
            // Check if DataTable is actually working
        setTimeout(function() {
            try {
                var info = table.page.info();
                console.log('📊 DataTable info after 3s:', info);
                console.log('📊 Visible rows:', table.rows().count());
                console.log('📊 Table data:', table.data().toArray());
                
                if (info.recordsTotal === 0) {
                    console.warn('⚠️ No records loaded, trying manual approach...');
                    loadDataDirectly();
                }
            } catch (e) {
                console.error('❌ Error checking DataTable status:', e);
                loadDataDirectly();
            }
        }, 3000);
        
        // Function to load data directly without DataTable
        function loadDataDirectly() {
            console.log('🔄 Loading data directly without DataTable...');
            
            $.ajax({
                url: "{{ route('recruitment.interviews.datatable') }}",
                type: 'GET',
                data: { draw: 1, start: 0, length: 50 },
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'X-CSRF-TOKEN': $('meta[name="csrf-token"]').attr('content')
                },
                success: function(response) {
                    console.log('📥 Direct load response:', response);
                    
                    if (response && response.data && response.data.length > 0) {
                        console.log('✅ Found ' + response.data.length + ' interviews, populating table...');
                        
                        // Clear existing DataTable
                        if ($.fn.DataTable.isDataTable('#interviewsTable')) {
                            $('#interviewsTable').DataTable().destroy();
                        }
                        
                        var tbody = $('#interviewsTable tbody');
                        tbody.empty();
                        
                        response.data.forEach(function(interview, index) {
                            var row = '<tr>' +
                                '<td>' + (index + 1) + '</td>' +
                                '<td>' + (interview.candidate || 'N/A') + '</td>' +
                                '<td>' + (interview.job_title || 'N/A') + '</td>' +
                                '<td>' + (interview.interviewer_name || 'N/A') + '</td>' +
                                '<td>' + (interview.scheduled_date || 'N/A') + '</td>' +
                                '<td>' + (interview.type_badge || 'N/A') + '</td>' +
                                '<td>' + (interview.status_badge || 'N/A') + '</td>' +
                                '<td>' + (interview.duration || 'N/A') + '</td>' +
                                '<td>' + (interview.action || '') + '</td>' +
                                '</tr>';
                            tbody.append(row);
                        });
                        
                        console.log('✅ Table populated directly with ' + response.data.length + ' rows');
                        
                        // Add a success message
                        $('<div class="alert alert-success alert-dismissible fade show mt-2">' +
                          '<strong>Success!</strong> Loaded ' + response.data.length + ' interviews directly.' +
                          '<button type="button" class="close" data-dismiss="alert">&times;</button>' +
                          '</div>').insertBefore('#interviewsTable');
                        
                    } else {
                        console.warn('⚠️ No interview data found');
                        $('#interviewsTable tbody').html('<tr><td colspan="9" class="text-center text-muted">No interviews scheduled</td></tr>');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('❌ Direct load failed:', xhr.status, error, xhr.responseText);
                    $('#interviewsTable tbody').html('<tr><td colspan="9" class="text-center text-danger">Error: ' + error + '</td></tr>');
                }
            });
        }        // Simple filter functionality - let form submit naturally for reliability
        $('#filterForm select, #filterForm input[type="date"]').on('change', function() {
            console.log('🔄 Filter changed, submitting form...');
            $('#filterForm')[0].submit(); // Natural form submission
        });

        // Filter form submission (keep preventDefault for manual submit button)
        $('#filterForm').on('submit', function(e) {
            console.log('📝 Form submitted manually');
            // Let it submit naturally - don't prevent default for better compatibility
        });

        // Simple and reliable filter approach - just log that filters are working
        console.log('🎯 Interview filters initialized - using simple form submission for reliability');

        // Complete interview modal
        $(document).on('click', '.complete-interview', function() {
            let interviewId = $(this).data('id');
            $('#interviewId').val(interviewId);
            $('#completeModal').modal('show');
        });

        // Complete interview form submission
        $('#completeForm').on('submit', function(e) {
            e.preventDefault();
            let interviewId = $('#interviewId').val();
            
            $.ajax({
                url: `/recruitment/interviews/${interviewId}/complete`,
                type: 'POST',
                data: {
                    _token: '{{ csrf_token() }}',
                    score: $('input[name="score"]').val(),
                    recommendation: $('select[name="recommendation"]').val(),
                    feedback: $('textarea[name="feedback"]').val()
                },
                success: function(response) {
                    if(response.success) {
                        toastr.success(response.message);
                        $('#completeModal').modal('hide');
                        table.draw();
                    } else {
                        toastr.error(response.message);
                    }
                },
                error: function() {
                    toastr.error('Something went wrong!');
                }
            });
        });

        // Reschedule interview modal
        $(document).on('click', '.reschedule-interview', function() {
            let interviewId = $(this).data('id');
            $('#rescheduleInterviewId').val(interviewId);
            $('#rescheduleModal').modal('show');
        });

        // Reschedule interview form submission
        $('#rescheduleForm').on('submit', function(e) {
            e.preventDefault();
            let interviewId = $('#rescheduleInterviewId').val();
            
            $.ajax({
                url: `/recruitment/interviews/${interviewId}/reschedule`,
                type: 'POST',
                data: {
                    _token: '{{ csrf_token() }}',
                    scheduled_at: $('input[name="scheduled_at"]').val(),
                    reason: $('textarea[name="reason"]').val()
                },
                success: function(response) {
                    if(response.success) {
                        toastr.success(response.message);
                        $('#rescheduleModal').modal('hide');
                        table.draw();
                    } else {
                        toastr.error(response.message);
                    }
                },
                error: function() {
                    toastr.error('Something went wrong!');
                }
            });
        });

        // Delete interview
        $(document).on('click', '.delete-interview', function(e) {
            e.preventDefault();
            let interviewId = $(this).data('id');
            
            Swal.fire({
                title: 'Are you sure?',
                text: "This action cannot be undone!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: `/recruitment/interviews/${interviewId}`,
                        type: 'DELETE',
                        data: {
                            _token: '{{ csrf_token() }}'
                        },
                        success: function(response) {
                            if(response.success) {
                                toastr.success(response.message);
                                table.draw();
                            } else {
                                toastr.error(response.message);
                            }
                        },
                        error: function() {
                            toastr.error('Something went wrong!');
                        }
                    });
                }
            });
        });

        // Fallback function to manually load interviews if DataTable fails
        function loadInterviewsManually() {
            console.log('🔄 Loading interviews manually as fallback...');
            
            $.ajax({
                url: "{{ route('recruitment.interviews.datatable') }}",
                type: 'GET',
                data: { draw: 1, start: 0, length: 10 },
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'X-CSRF-TOKEN': $('meta[name="csrf-token"]').attr('content')
                },
                success: function(response) {
                    console.log('📥 Manual load response:', response);
                    
                    if (response.data && response.data.length > 0) {
                        console.log('✅ Manual load successful, populating table...');
                        
                        var tbody = $('#interviewsTable tbody');
                        tbody.empty();
                        
                        response.data.forEach(function(interview) {
                            var row = '<tr>' +
                                '<td>' + interview.DT_RowIndex + '</td>' +
                                '<td>' + interview.candidate + '</td>' +
                                '<td>' + interview.job_title + '</td>' +
                                '<td>' + interview.interviewer_name + '</td>' +
                                '<td>' + interview.scheduled_date + '</td>' +
                                '<td>' + interview.type_badge + '</td>' +
                                '<td>' + interview.status_badge + '</td>' +
                                '<td>' + interview.duration + '</td>' +
                                '<td>' + interview.action + '</td>' +
                                '</tr>';
                            tbody.append(row);
                        });
                        
                        console.log('✅ Table populated with ' + response.data.length + ' rows');
                    } else {
                        console.warn('⚠️ No data received in manual load');
                        $('#interviewsTable tbody').html('<tr><td colspan="9" class="text-center">No interviews found</td></tr>');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('❌ Manual load failed:', error);
                    $('#interviewsTable tbody').html('<tr><td colspan="9" class="text-center text-danger">Error loading interviews: ' + error + '</td></tr>');
                }
            });
        }

        } // End initDataTable function
        
        // Initialize Select2
        $('.select2').select2({
            placeholder: 'Select...',
            allowClear: true
        });
        
        // Add manual load button for debugging
        $('<button class="btn btn-warning btn-sm ml-2">Load Data Manually</button>')
            .appendTo('.card-header')
            .on('click', function() {
                console.log('🔧 Manual load triggered by user');
                // Call the function from the outer scope
                $.ajax({
                    url: "{{ route('recruitment.interviews.datatable') }}",
                    type: 'GET',
                    data: { draw: 1, start: 0, length: 10 },
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'X-CSRF-TOKEN': $('meta[name="csrf-token"]').attr('content')
                    },
                    success: function(response) {
                        console.log('📥 Manual load response:', response);
                        
                        if (response.data && response.data.length > 0) {
                            var tbody = $('#interviewsTable tbody');
                            tbody.empty();
                            
                            response.data.forEach(function(interview) {
                                var row = '<tr>' +
                                    '<td>' + interview.DT_RowIndex + '</td>' +
                                    '<td>' + interview.candidate + '</td>' +
                                    '<td>' + interview.job_title + '</td>' +
                                    '<td>' + interview.interviewer_name + '</td>' +
                                    '<td>' + interview.scheduled_date + '</td>' +
                                    '<td>' + interview.type_badge + '</td>' +
                                    '<td>' + interview.status_badge + '</td>' +
                                    '<td>' + interview.duration + '</td>' +
                                    '<td>' + interview.action + '</td>' +
                                    '</tr>';
                                tbody.append(row);
                            });
                            
                            console.log('✅ Manual table populated with ' + response.data.length + ' rows');
                            alert('Data loaded successfully! Found ' + response.data.length + ' interviews.');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('❌ Manual load failed:', error);
                        alert('Failed to load data: ' + error);
                    }
                });
            });
    });

    // Interview Action Functions
    function deleteInterview(id) {
        if (confirm('Are you sure you want to delete this interview?')) {
            console.log('Attempting to delete interview ID:', id);
            
            $.ajax({
                url: `{{ url('recruitment/interviews') }}/${id}`,
                type: 'DELETE',
                data: {
                    _token: $('meta[name="csrf-token"]').attr('content'),
                    _method: 'DELETE'
                },
                headers: {
                    'X-CSRF-TOKEN': $('meta[name="csrf-token"]').attr('content'),
                    'Accept': 'application/json',
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                beforeSend: function() {
                    console.log('Sending delete request...');
                },
                success: function(response) {
                    console.log('Delete response:', response);
                    if (response.success) {
                        showToast('Interview deleted successfully.', 'success');
                        // Reload the page or refresh the table
                        setTimeout(function() {
                            window.location.reload();
                        }, 1000);
                    } else {
                        showToast(response.message || 'Failed to delete interview', 'error');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Delete error:', xhr.responseText, status, error);
                    let errorMessage = 'Failed to delete interview';
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        errorMessage = xhr.responseJSON.message;
                    } else if (xhr.status === 403) {
                        errorMessage = 'Permission denied. You do not have access to delete interviews.';
                    } else if (xhr.status === 404) {
                        errorMessage = 'Interview not found.';
                    } else if (xhr.status === 419) {
                        errorMessage = 'Session expired. Please refresh the page.';
                    }
                    showToast(errorMessage, 'error');
                }
            });
        }
    }

    function completeInterview(id) {
        if (confirm('Mark this interview as completed?')) {
            $.ajax({
                url: `/recruitment/interviews/${id}/complete`,
                type: 'POST',
                headers: {
                    'X-CSRF-TOKEN': $('meta[name="csrf-token"]').attr('content')
                },
                success: function(response) {
                    if (response.success) {
                        showToast('Interview completed successfully!', 'success');
                        window.location.reload();
                    } else {
                        showToast(response.message || 'Failed to complete interview', 'error');
                    }
                },
                error: function(xhr) {
                    showToast('Failed to complete interview', 'error');
                }
            });
        }
    }

    function rescheduleInterview(id) {
        const newDate = prompt('Enter new date and time (YYYY-MM-DD HH:MM):');
        if (newDate) {
            $.ajax({
                url: `/recruitment/interviews/${id}/reschedule`,
                type: 'POST',
                data: {
                    new_date: newDate,
                    reason: 'Rescheduled from interview list'
                },
                headers: {
                    'X-CSRF-TOKEN': $('meta[name="csrf-token"]').attr('content')
                },
                success: function(response) {
                    if (response.success) {
                        showToast('Interview rescheduled successfully!', 'success');
                        window.location.reload();
                    } else {
                        showToast(response.message || 'Failed to reschedule interview', 'error');
                    }
                },
                error: function(xhr) {
                    showToast('Failed to reschedule interview', 'error');
                }
            });
        }
    }

    function cancelInterview(id) {
        const reason = prompt('Reason for cancellation:');
        if (reason) {
            $.ajax({
                url: `/recruitment/interviews/${id}/cancel`,
                type: 'POST',
                data: {
                    reason: reason
                },
                headers: {
                    'X-CSRF-TOKEN': $('meta[name="csrf-token"]').attr('content')
                },
                success: function(response) {
                    if (response.success) {
                        showToast('Interview cancelled successfully!', 'success');
                        window.location.reload();
                    } else {
                        showToast(response.message || 'Failed to cancel interview', 'error');
                    }
                },
                error: function(xhr) {
                    showToast('Failed to cancel interview', 'error');
                }
            });
        }
    }

    function confirmDelete() {
        return confirm('Are you sure you want to delete this interview schedule?');
    }

    function showToast(message, type = 'info') {
        // Create toast notification
        const toast = $(`
            <div class="alert alert-${type === 'error' ? 'danger' : type} alert-dismissible fade show position-fixed" style="top: 20px; right: 20px; z-index: 9999; min-width: 300px;">
                <i class="fas fa-${type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle'}"></i>
                ${message}
                <button type="button" class="close" data-dismiss="alert">
                    <span>&times;</span>
                </button>
            </div>
        `);
        
        $('body').append(toast);
        
        // Auto remove after 5 seconds
        setTimeout(() => {
            toast.remove();
        }, 5000);
    }
</script>
@endsection